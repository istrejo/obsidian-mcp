{
  "name": "@istrejo/obsidian-mcp",
  "version": "0.1.0",
  "description": "MCP server for Obsidian vaults via direct filesystem access. Works with Claude Desktop and Claude Code.",
  "type": "module",
  "bin": {
    "obsidian-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "claude",
    "claude-code",
    "claude-desktop",
    "notes",
    "knowledge-management",
    "ai"
  ],
  "author": "José Alejandro Trejo Rivera <istrejo2106@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/istrejo/obsidian-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/istrejo/obsidian-mcp/issues"
  },
  "homepage": "https://github.com/istrejo/obsidian-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.1.3",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
